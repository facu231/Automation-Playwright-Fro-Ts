{
  "name": "framework-fro-ts",
  "version": "1.0.0",
  "description": "Framework corporativo de automatizacion E2E frontend con Playwright, TypeScript, Cucumber y BDD.",
  "private": true,
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:qa": "cross-env TEST_ENV=qa cucumber-js --config cucumber.js",
    "test:dev": "cross-env TEST_ENV=dev cucumber-js --config cucumber.js",
    "test:headed": "cross-env HEADLESS=false cucumber-js --config cucumber.js",
    "test:debug": "cross-env PWDEBUG=1 HEADLESS=false cucumber-js --config cucumber.js",
    "report": "ts-node src/utils/generate-report.ts",
    "clean:reports": "rimraf reports screenshots videos traces test-results",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "gherkin",
    "bdd",
    "typescript",
    "qa-automation",
    "e2e"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@playwright/test": "^1.45.3",
    "@types/node": "^20.14.10",
    "cross-env": "^7.0.3",
    "multiple-cucumber-html-reporter": "^3.8.0",
    "playwright": "^1.45.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
